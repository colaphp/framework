{
  "name": "colasoft/framework",
  "description": "High performance HTTP Service Framework.",
  "keywords": ["framework", "colaphp"],
  "license": "MIT",
  "homepage": "https://www.colaphp.net",
  "support": {
    "issues": "https://github.com/colaphp/framework/issues",
    "source": "https://github.com/colaphp/framework"
  },
  "require": {
    "php": "^8.1",
    "ext-fileinfo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "doctrine/annotations": "^2.0",
    "filp/whoops": "^2.14",
    "firebase/php-jwt": "^6.3",
    "gregwar/captcha": "^1.1",
    "illuminate/database": "^9.45",
    "illuminate/events": "^9.45",
    "illuminate/pagination": "^9.45",
    "illuminate/redis": "^9.45",
    "illuminate/view": "^9.45",
    "intervention/image": "^2.7",
    "monolog/monolog": "^3.2",
    "nikic/fast-route": "^1.3",
    "overtrue/easy-sms": "^2.3",
    "overtrue/pinyin": "^5.0",
    "php-di/php-di": "^6.4",
    "phpoffice/phpspreadsheet": "^1.26",
    "robmorgan/phinx": "^0.13",
    "symfony/cache": "^6.2",
    "symfony/mailer": "^6.2",
    "vlucas/phpdotenv": "^5.5",
    "w7corp/easywechat": "^5.31",
    "workerman/crontab": "^1.0",
    "workerman/gateway-worker": "^4.0",
    "workerman/redis-queue": "^1.0",
    "yansongda/pay": "^3.2"
  },
  "autoload": {
    "psr-4": {
      "Cola\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "suggest": {
    "ext-event": "For better performance. "
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
